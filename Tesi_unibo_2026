#### GRAFICO FRIEDMAN

# 1. Installa e carica il pacchetto per i grafici (fallo solo se non lo hai già)
# install.packages("ggplot2")
library(ggplot2)

# 2. Crea il grafico
Grafico_Friedman_2025 <- ggplot(dati2025, aes(x = Transetto, y = Abbondanza, fill = Transetto)) +
  # Disegna i boxplot semitrasparenti per vedere i punti sotto
  geom_boxplot(alpha = 0.6, outlier.shape = NA) +
  # Aggiunge i punti delle 49 specie evitando che si sovrappongano perfettamente
  geom_jitter(width = 0.2, alpha = 0.5, color = "black") +
  # Applica un tema grafico pulito e professionale
  theme_minimal() +
  # Personalizza i colori dei transetti (puoi cambiarli a piacimento)
  scale_fill_brewer(palette = "Dark2") +
  # Rimuove la legenda laterale poiché i transetti sono già indicati sull'asse X
  theme(legend.position = "none") +
  # Aggiunge i testi e i titoli degli assi
  labs(
    title = "Distribuzione delle specie nei tre transetti",
    subtitle = "Test di Friedman: p-value = 0.1585 (Non Significativo)",
    x = "Transetti di Campionamento",
    y = "Dominanza % per Specie"
  )
Grafico_Friedman_2025

# Grafico con scala logaritmica sull'asse Y per renderlo visivamente più equilibrato.
#install.packages("scales") 

# Crea il grafico con l'asse Y in scala logaritmica (log10 + 1)
Grafico_2025 <- ggplot(dati2025, aes(x = Transetto, y = Abbondanza, fill = Transetto)) +
  # Disegna i boxplot senza mostrare gli outlier (evita duplicati con geom_jitter)
  geom_boxplot(alpha = 0.6, outlier.shape = NA) +
  # Mostra le 49 specie come punti spaziati
  geom_jitter(width = 0.2, alpha = 0.5, color = "black") +
  # Trasforma l'asse Y in scala logaritmica inserendo etichette con i numeri reali
  scale_y_log10(labels = scales::label_comma(), breaks = c(0, 1, 2, 5, 10, 20, 50, 100)) +
  # Applica un tema grafico pulito
  theme_minimal() +
  scale_fill_brewer(palette = "Dark2") +
  theme(legend.position = "none") +
  labs(
    title = "Distribuzione delle specie nei tre transetti (Scala Logaritmica)",
    subtitle = "Test di Friedman: p-value = 0.1585 (Non Significativo)",
    x = "Transetti di Campionamento",
    y = "Dominanza % per Specie (Scala Log)"
  )
Grafico_2025

# Salva il grafico nella cartella di lavoro corrente
