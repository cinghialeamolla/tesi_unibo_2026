#### WILCOXON SPONDE TAGLI

# 1. CARICAMENTO DEI DATI
# Importa il file CSV (R riconosce automaticamente la struttura)
dati_tagli <- read_excel("dati_tagli_2025.xlsx")

# Visualizza l'anteprima per verificare che sia corretto
head(dati_tagli)

# 2. ESECUZIONE DEL TEST DI WILCOXON
# Usiamo la funzione nativa wilcox.test() impostando:
# paired = TRUE  -> specifica che i campioni sono appaiati (stesse 33 specie)
# exact = FALSE  -> usa l'approssimazione normale con correzione (come fatto su Excel)

risultato <- wilcox.test(dati_tagli$T_sx, dati_tagli$T_dx, 
                         paired = TRUE, 
                         exact = FALSE, 
                         correct = TRUE)

# 3. VISUALIZZAZIONE DEL RISULTATO
wilcoxon_tagli <- print(risultato)
wilcoxon_tagli

#        Wilcoxon signed rank test with continuity correction
#data:  dati_tagli$T_sx and dati_tagli$T_dx
#V = 302.5, p-value = 0.7008
#alternative hypothesis: true location shift is not equal to 0

