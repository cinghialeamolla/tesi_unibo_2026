### ricchezza di specie (Species Richness) per ciascun transetto

# 1. Installa e carica il pacchetto dplyr per la manipolazione dei dati
# install.packages("dplyr")
library(dplyr)

# 2. Calcola la ricchezza di specie e i contatti totali per transetto
setwd("C:/Runibo")
coppie2025 <- read_excel("C:/Runibo/dati_coppie_2025.xlsx")
tabella_ricchezza <- coppie2025 %>%
  # Filtra eliminando le righe dove la specie non è stata contattata
  filter(Coppie > 0) %>%
  # Raggruppa i dati per transetto
  group_by(Transetto) %>%
  # Calcola le metriche
  summarise(
    Ricchezza_Specie = n_distinct(Specie), # Conta le specie uniche presenti
    Contatti_Totali = sum(Coppie)        # Somma tutti gli uccelli visti
  )

# 3. Mostra la tabella dei risultati
print(tabella_ricchezza)

# A tibble: 3 × 3
# Transetto Ricchezza_Specie Contatti_Totali
# <chr>                <int>           <dbl>
# 1 T1                      40            430.
# 2 T2                      39            406 
# 3 T3                      33            376.

#### indice di biodiversità di Shannon-Wiener (\(H^{\prime }\))

# 1. Installa e carica il pacchetto vegan per l'ecologia dei dati
# install.packages("vegan")
# install.packages("tidyr")
library(vegan)
library(dplyr)
library(tidyr)

# 2. Trasforma i dati nel formato richiesto da vegan (matrice sito x specie)
 matrice_comunita <- coppie2025 %>%
  # Seleziona solo le colonne necessarie
  select(Transetto, Specie, Coppie) %>%
  # Ruota la tabella mettendo le specie come colonne e i transetti come righe
  tidyr::pivot_wider(names_from = Specie, values_from = Coppie, values_fill = 0) %>%
  # Imposta il nome del transetto come indice della riga
  tibble::column_to_rownames(var = "Transetto")

# 3. Calcola l'indice di Shannon-Wiener (base del logaritmo naturale)
shannon_transetti <- diversity(matrice_comunita, index = "shannon")

# 4. Calcola l'Equoripartizione di Pielou (Evenness, J')
# Indica quanto le specie sono distribuite equamente (va da 0 a 1)
ricchezza <- specnumber(matrice_comunita)
pielou_transetti <- shannon_transetti / log(ricchezza)

# 5. Unisci i risultati in un'unica tabella pulita
risultati_biodiversita <- data.frame(
  Transetto = rownames(matrice_comunita),
  Ricchezza_Specie = ricchezza,
  Indice_Shannon = round(shannon_transetti, 3),
  Equitabilita_Pielou = round(pielou_transetti, 3)
)

# 6. Visualizza la tabella finale
print(risultati_biodiversita)

#      Transetto Ricchezza_Specie Indice_Shannon Equitabilita_Pielou
#T1        T1               40          3.042               0.825
#T2        T2               39          3.007               0.821
#T3        T3               33          2.903               0.830
 



##### CALCOLO FRIEDMAN 2025

# 1. Installa e carica il pacchetto per leggere i file Excel
# install.packages("readxl")
library("readxl")


# 2. Importa i tuoi dati da Excel
setwd("C:/Runibo")
dati2025 <- read_excel("C:/Runibo/dati_ornitologia_2025.xlsx")

# 3. Controlla l'anteprima dei dati per verificare che sia tutto corretto
head(dati2025)

# 4. Esegui il test di Friedman
risultato_test <- friedman.test(Abbondanza ~ Transetto | Specie, data = dati2025)

# 5. Visualizza il risultato a schermo
Friedman_2025 <- print(risultato_test)
Friedman_2025



#Friedman rank sum test
#data:  Abbondanza and Transetto and Specie
